# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Azure OpenAI (get from Azure portal)
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
AZURE_OPENAI_KEY=your_key_here
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o

# Google Gemini (embeddings + RAG chat)
GEMINI_API_KEY=your_gemini_api_key

# Fallback: OpenAI direct (if not using Azure, e.g. for agent tool-calling)
OPENAI_API_KEY=sk-...

# Microsoft Foundry (for MCP agent)
FOUNDRY_API_KEY=your_foundry_key
FOUNDRY_PROJECT_ID=your_project_id

# Frontend
VITE_API_URL=http://localhost:3000

